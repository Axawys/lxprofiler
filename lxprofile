#!/usr/bin/env bash
# lxprofile — Linux Psychological Profiler
# Точка входа: разбор аргументов и запуск движка из lib/.
# Requires: bash 4.0+, standard coreutils, tput (ncurses); git — для --update

# Без set -e: grep, pidof, (( )) штатно возвращают ненулевой код
set -uo pipefail

# ──────────────────────────────────────────────
# Определяем реальный каталог скрипта (с учётом симлинков из ~/.local/bin)
# ──────────────────────────────────────────────
SOURCE="${BASH_SOURCE[0]}"
while [[ -h "$SOURCE" ]]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
LXPROFILE_ROOT="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
LXPROFILE_LIB="$LXPROFILE_ROOT/lib"

source "$LXPROFILE_LIB/version.sh"
source "$LXPROFILE_LIB/update.sh"

# ──────────────────────────────────────────────
# Обработка прерывания (Ctrl+C / SIGTERM)
# Вне TUI: показываем курсор, прибираем фоновую проверку и выходим аккуратно.
# Внутри TUI свой обработчик ставит interactive_view (с восстановлением экрана).
# ──────────────────────────────────────────────
_interrupt() {
  tput cnorm 2>/dev/null
  [[ -n ${LXPROFILE_UPD_PID:-} ]] && kill "$LXPROFILE_UPD_PID" 2>/dev/null
  [[ -n ${LXPROFILE_UPD_RESULT:-} && -e ${LXPROFILE_UPD_RESULT:-} ]] && rm -f "$LXPROFILE_UPD_RESULT" 2>/dev/null
  printf '\nПрервано.\n' >&2
  exit 130
}
trap _interrupt INT TERM

# ──────────────────────────────────────────────
# Подкоманды: --version / --help / --update / --remove
# ──────────────────────────────────────────────

print_version() {
  local v="$LXPROFILE_VERSION"
  if command -v git >/dev/null 2>&1 \
     && git -C "$LXPROFILE_ROOT" rev-parse --git-dir >/dev/null 2>&1; then
    local hash
    hash=$(git -C "$LXPROFILE_ROOT" rev-parse --short HEAD 2>/dev/null)
    [[ -n $hash ]] && v="$v ($hash)"
  fi
  printf 'lxprofile %s\n' "$v"
}

print_help() {
  cat <<'EOF'
lxprofile — Linux Psychological Profiler

ИСПОЛЬЗОВАНИЕ:
  lxprofile [ОПЦИЯ]

  Без опций запускает профайлер: в терминале — интерактивно,
  в пайпе или не-TTY — статической сводкой.

ОПЦИИ:
  -u, --update          обновить lxprofile с GitHub
      --rm, --remove    удалить lxprofile из системы
  -v, --version         показать версию
  -h, --help            показать эту справку

УПРАВЛЕНИЕ (интерактивный режим):
  k, ↑                  переместить выбор вверх
  j, ↓                  переместить выбор вниз
  g                     к первому архетипу
  G                     к последнему архетипу
  m                     сменить режим (список / компас / статистика)
  q                     выход

Разработано Axawys.
GitHub: https://github.com/Axawys/lxprofiler
EOF
}

# Удаляет утилиту: симлинк в PATH, состояние и (если это стандартная
# установка через install.sh) каталог установки.
do_remove() {
  local bin_link="${LXPROFILE_BIN:-$HOME/.local/bin}/lxprofile"
  local install_default="${LXPROFILE_HOME:-$HOME/.local/share/lxprofiler}"
  local in_path remove_dir=""

  # Симлинк, найденный в PATH (если отличается от стандартного)
  in_path=$(command -v lxprofile 2>/dev/null || true)

  # Каталог установки удаляем только если это стандартное место install.sh —
  # чтобы случайно не снести dev-чекаут репозитория.
  if [[ "$LXPROFILE_ROOT" == "$install_default" \
        || "$LXPROFILE_ROOT" == "$HOME/.local/share/lxprofiler" ]]; then
    remove_dir="$LXPROFILE_ROOT"
  fi

  printf 'Будет удалено:\n'
  [[ -L $bin_link || -e $bin_link ]]            && printf '  • симлинк   %s\n' "$bin_link"
  [[ -n $in_path && -L $in_path && $in_path != "$bin_link" ]] \
                                                && printf '  • симлинк   %s\n' "$in_path"
  [[ -d $LXPROFILE_STATE_DIR ]]                 && printf '  • состояние %s\n' "$LXPROFILE_STATE_DIR"
  if [[ -n $remove_dir ]]; then
    printf '  • каталог   %s\n' "$remove_dir"
  else
    printf '  (каталог %s оставлен — это не стандартная установка)\n' "$LXPROFILE_ROOT"
  fi

  printf 'Продолжить удаление? [y/N] '
  local ans=""
  read -r ans </dev/tty 2>/dev/null || ans=""
  case "$ans" in
    y|Y|yes|Yes|да|Да|д|Д) ;;
    *) printf 'Отменено.\n'; return 1 ;;
  esac

  rm -f "$bin_link" 2>/dev/null
  [[ -n $in_path && -L $in_path && $in_path != "$bin_link" ]] && rm -f "$in_path" 2>/dev/null
  rm -rf "$LXPROFILE_STATE_DIR" 2>/dev/null
  if [[ -n $remove_dir ]]; then
    rm -rf "$remove_dir" 2>/dev/null
    printf 'lxprofile удалён. Спасибо, что пользовались! 🐧\n'
  else
    printf 'Симлинк и состояние удалены. Исходный каталог оставлен:\n  %s\n' "$LXPROFILE_ROOT"
  fi
}

case "${1:-}" in
  -v|--version) print_version; exit 0 ;;
  -h|--help)    print_help;    exit 0 ;;
  -u|--update)  do_update;     exit $? ;;
  --rm|--remove) do_remove;    exit $? ;;
  "")           : ;;  # без аргументов — запускаем профайлер
  *)
    printf 'Неизвестный аргумент: %s\n\n' "$1" >&2
    print_help >&2
    exit 1
    ;;
esac

# ──────────────────────────────────────────────
# Проверка обновлений стартует В ФОНЕ — чтобы утилита открывалась сразу,
# а уведомление о новой версии показывалось уже после закрытия просмотра.
# ──────────────────────────────────────────────
start_update_check

# ──────────────────────────────────────────────
# Движок: данные → утилиты → анализ → отрисовка
# Порядок важен: detect.sh использует data.sh и helpers.sh.
# ──────────────────────────────────────────────
source "$LXPROFILE_LIB/data.sh"
source "$LXPROFILE_LIB/helpers.sh"
source "$LXPROFILE_LIB/detect.sh"
source "$LXPROFILE_LIB/compass.sh"
source "$LXPROFILE_LIB/stats.sh"
source "$LXPROFILE_LIB/render.sh"

# ──────────────────────────────────────────────
# Точка входа
# В настоящем терминале — интерактивный режим; для пайпа — статическая сводка.
# ──────────────────────────────────────────────
if [[ -t 0 && -t 1 ]] && has tput; then
  interactive_view
  # interactive_view снимает свои trap'ы — возвращаем обработчик прерывания
  trap _interrupt INT TERM
  # После закрытия просмотра — результат фоновой проверки обновлений
  finish_update_check
else
  print_static
fi
